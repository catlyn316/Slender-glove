end)

-- 第五個按鈕：自動獲取紙頁
EgglerButtons[5].MouseButton1Click:Connect(function()
	local Pages = Workspace:FindFirstChild("Pages")
	if Pages then
		local children = Pages:GetChildren()
		task.spawn(function()
			for _, page in ipairs(children) do
				local part = page:FindFirstChild("Part")
				if part and part:FindFirstChildWhichIsA("ProximityPrompt") then
					LocalPlayer.Character:MoveTo(part.Position)
					task.wait(0.5)
					fireproximityprompt(part:FindFirstChildWhichIsA("ProximityPrompt"))
					task.wait(2)
				end
			end
		end)
	end
end)

-- 第六個按鈕：開啟 FullBright（Loop）
local fullBrightEnabled = false
local function enableFullBright()
	fullBrightEnabled = true
	task.spawn(function()
		while fullBrightEnabled do
			Lighting = game:GetService("Lighting")
			Lighting.Brightness = 2
			Lighting.ClockTime = 12
			Lighting.FogEnd = 100000
			Lighting.GlobalShadows = false
			Lighting.Ambient = Color3.new(1, 1, 1)
			task.wait(1)
		end
	end)
end

local fbBtn = createButton("開啟 FullBright", 6, EgglerScroll, 35)
table.insert(EgglerButtons, fbBtn)
fbBtn.Visible = true
fbBtn.MouseButton1Click:Connect(function()
	if not fullBrightEnabled then
		enableFullBright()
	end
end)


